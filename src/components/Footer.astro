---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-forest-light mt-auto">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-col items-center md:items-start gap-3">
        <img
          src="/logo-condensed-green.png"
          alt="Green Agaric"
          class="h-8 w-auto"
        />
        <p class="text-earth-base text-sm">
          &copy; {currentYear} Green Agaric. Ideas Wandering Off Trail.
        </p>
      </div>
      <p class="text-earth-base text-sm">
        Seattle, WA
      </p>
    </div>
  </div>
</footer>
