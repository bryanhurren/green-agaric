---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, status, link, logo } = project.data;

const statusColors = {
  'In Development': 'bg-forest-base text-white',
  'Early Prototype': 'bg-moss text-white',
  'Live': 'bg-forest-dark text-white',
  'Archived': 'bg-earth-base text-white',
  'Backlog': 'bg-earth-dark text-white',
};
---

<article class="border border-forest-light rounded-lg p-6 hover:shadow-lg transition-shadow">
  <div class="flex items-center gap-3 mb-2">
    {logo && (
      <img
        src={logo}
        alt={`${title} logo`}
        class="h-8 w-8 object-contain"
      />
    )}
    <h3 class="text-xl font-semibold text-forest-dark">{title}</h3>
    <span class={`inline-block px-3 py-1 text-sm rounded ${statusColors[status]}`}>
      {status}
    </span>
  </div>
  <p class="text-earth-base mb-4">{description}</p>
  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="text-forest-base hover:text-forest-dark transition-colors inline-block"
    >
      Visit project →
    </a>
  )}
</article>
