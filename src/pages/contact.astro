---
import BaseLayout from '@/layouts/BaseLayout.astro';

const pageTitle = 'Contact | Green Agaric';
const pageDescription = 'Get in touch with Green Agaric about collaborations at the intersection of AI, developer platforms, and creative systems';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="container mx-auto px-4 py-12 flex-1">
    <h1 class="text-4xl font-bold text-forest-dark mb-4">Contact</h1>
    <p class="text-lg text-earth-base mb-8">
      Interested in collaborations at the intersection of AI, developer platforms, and creative systems? Get in touch.
    </p>

    <div class="max-w-2xl">
      <form
        class="space-y-6"
        method="POST"
        action="https://formspree.io/f/mnnrndwo"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-forest-dark mb-2">
            Name <span class="text-red-600">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2 border border-forest-light rounded-lg focus:outline-none focus:ring-2 focus:ring-forest-base"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-forest-dark mb-2">
            Email <span class="text-red-600">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-forest-light rounded-lg focus:outline-none focus:ring-2 focus:ring-forest-base"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-forest-dark mb-2">
            Message <span class="text-red-600">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            class="w-full px-4 py-2 border border-forest-light rounded-lg focus:outline-none focus:ring-2 focus:ring-forest-base"
          ></textarea>
        </div>

        <!-- Honeypot field for spam protection -->
        <input type="text" name="_gotcha" style="display:none" />

        <div>
          <button
            type="submit"
            class="bg-forest-base text-white px-6 py-3 rounded-lg hover:bg-forest-dark transition-colors focus:outline-none focus:ring-2 focus:ring-forest-base focus:ring-offset-2"
          >
            Send Message
          </button>
        </div>

        <p class="text-sm text-earth-base">
          We'll get back to you as soon as possible.
        </p>
      </form>
    </div>
  </main>
</BaseLayout>
